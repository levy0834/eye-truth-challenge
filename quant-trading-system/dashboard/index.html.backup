<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>沪深300策略回测分析看板</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
        body { background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%); min-height: 100vh; }
        
        /* 玻璃拟态卡片 */
        .glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
        }
        
        /* 霓虹渐变边框 */
        .neon-border {
            position: relative;
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(236, 72, 153, 0.1));
            border-radius: 16px;
            padding: 1px;
        }
        .neon-border > div { background: rgba(17, 24, 39, 0.95); border-radius: 15px; }
        
        /* 自定义滚动条 */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: rgba(255,255,255,0.05); }
        ::-webkit-scrollbar-thumb { background: rgba(139, 92, 246, 0.5); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(139, 92, 246, 0.8); }
        
        /* 加载动画 */
        .pulse-dot {
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        /* 策略颜色映射 */
        .strategy-ma { color: #3b82f6; }
        .strategy-macd { color: #10b981; }
        .strategy-rsi { color: #f59e0b; }
        .strategy-bollinger { color: #ef4444; }
        .strategy-confluence { color: #8b5cf6; }
        
        /* 表格样式 */
        .data-table { overflow-x: auto; }
        .data-table th { background: rgba(99, 102, 241, 0.2); color: #a5b4fc; font-weight: 600; }
        .data-table td, .data-table th { padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .data-table tr:hover { background: rgba(99, 102, 241, 0.05); }
        
        /* 收益正负颜色 */
        .return-pos { color: #10b981; }
        .return-neg { color: #ef4444; }
    </style>
</head>
<body class="text-gray-100">
    <div class="container mx-auto px-4 py-8 max-w-7xl">
        <!-- 标题区域 -->
        <header class="mb-12">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-4xl font-bold bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
                        A股量化策略分析看板
                    </h1>
                    <p class="text-gray-400 mt-2 text-lg">沪深300成分股 · 20年历史数据 · 5种交易策略</p>
                </div>
                <div class="flex items-center space-x-2">
                    <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 rounded-full text-sm border border-indigo-500/30">
                        实时数据
                    </span>
                    <span class="text-gray-500 text-sm" id="update-time"></span>
                </div>
            </div>
        </header>

        <!-- KPI 卡片区域 -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
            <div class="glass-card p-6 hover:transform hover:scale-105 transition-transform duration-300">
                <div class="text-gray-400 text-sm font-medium mb-2">回测总次数</div>
                <div class="text-3xl font-bold text-white" id="total-backtests">--</div>
                <div class="text-gray-500 text-xs mt-1">策略 × 股票</div>
            </div>
            <div class="glass-card p-6 hover:transform hover:scale-105 transition-transform duration-300">
                <div class="text-gray-400 text-sm font-medium mb-2">覆盖股票</div>
                <div class="text-3xl font-bold text-indigo-400" id="stock-count">--</div>
                <div class="text-gray-500 text-xs mt-1">沪深300成分股</div>
            </div>
            <div class="glass-card p-6 hover:transform hover:scale-105 transition-transform duration-300">
                <div class="text-gray-400 text-sm font-medium mb-2">最佳策略</div>
                <div class="text-xl font-bold text-green-400" id="best-strategy">--</div>
                <div class="text-gray-500 text-xs mt-1">平均测试收益</div>
            </div>
            <div class="glass-card p-6 hover:transform hover:scale-105 transition-transform duration-300">
                <div class="text-gray-400 text-sm font-medium mb-2">最优收益</div>
                <div class="text-3xl font-bold text-emerald-400" id="best-return">--</div>
                <div class="text-gray-500 text-xs mt-1">测试集年化</div>
            </div>
        </section>

        <!-- 策略表现对比 -->
        <section class="mb-12">
            <h2 class="text-2xl font-bold mb-6 flex items-center">
                <span class="w-2 h-8 bg-gradient-to-b from-indigo-500 to-purple-500 rounded mr-3"></span>
                策略表现对比
            </h2>
            <div class="glass-card p-6 overflow-x-auto">
                <table class="w-full data-table" id="strategy-table">
                    <thead>
                        <tr>
                            <th class="text-left">策略</th>
                            <th class="text-right">平均收益 %</th>
                            <th class="text-right">标准差 %</th>
                            <th class="text-right">最大回撤 %</th>
                            <th class="text-right">夏普比率</th>
                            <th class="text-right">胜率 %</th>
                            <th class="text-right">股票数量</th>
                        </tr>
                    </thead>
                    <tbody id="strategy-table-body"></tbody>
                </table>
            </div>
        </section>

        <!-- 详细结果表格 + 图表 -->
        <section class="mb-12">
            <div class="flex flex-col lg:flex-row gap-6">
                <!-- 左侧：详细表格 -->
                <div class="lg:w-2/3">
                    <h2 class="text-2xl font-bold mb-6 flex items-center">
                        <span class="w-2 h-8 bg-gradient-to-b from-pink-500 to-rose-500 rounded mr-3"></span>
                        详细回测结果
                    </h2>
                    <div class="glass-card p-6 overflow-hidden">
                        <div class="mb-4 flex flex-wrap gap-3">
                            <select id="filter-strategy" class="bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                <option value="all">所有策略</option>
                                <option value="MACrossStrategy">MA均线</option>
                                <option value="MACDCrossStrategy">MACD</option>
                                <option value="RSIStrategy">RSI</option>
                                <option value="BollingerStrategy">布林带</option>
                                <option value="TAConfluenceStrategy">多因子共振</option>
                            </select>
                            <select id="sort-by" class="bg-gray-800 border border-gray-700 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                <option value="test_return_pct">按测试收益</option>
                                <option value="test_sharpe">按夏普比率</option>
                                <option value="test_maxdd_pct">按最大回撤</option>
                                <option value="symbol">按股票代码</option>
                            </select>
                            <button id="refresh-btn" class="bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                                刷新
                            </button>
                        </div>
                        <div class="data-table max-h-[600px] overflow-y-auto rounded-lg">
                            <table class="w-full">
                                <thead class="sticky top-0 bg-gray-900 z-10">
                                    <tr>
                                        <th class="text-left cursor-pointer" onclick="sortData('symbol')">股票代码 ⇅</th>
                                        <th class="text-left cursor-pointer" onclick="sortData('strategy')">策略 ⇅</th>
                                        <th class="text-right cursor-pointer" onclick="sortData('test_return_pct')">测试收益% ⇅</th>
                                        <th class="text-right cursor-pointer" onclick="sortData('test_sharpe')">夏普 ⇅</th>
                                        <th class="text-right cursor-pointer" onclick="sortData('test_maxdd_pct')">最大回撤% ⇅</th>
                                        <th class="text-right">胜率%</th>
                                        <th class="text-right">交易次数</th>
                                    </tr>
                                </thead>
                                <tbody id="detailed-table-body"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 右侧：收益分布图 -->
                <div class="lg:w-1/3">
                    <h2 class="text-2xl font-bold mb-6 flex items-center">
                        <span class="w-2 h-8 bg-gradient-to-b from-emerald-500 to-cyan-500 rounded mr-3"></span>
                        收益分布
                    </h2>
                    <div class="glass-card p-6">
                        <canvas id="return-distribution-chart" height="300"></canvas>
                    </div>
                    
                    <!-- 策略表现雷达图 -->
                    <h2 class="text-2xl font-bold mt-8 mb-6 flex items-center">
                        <span class="w-2 h-8 bg-gradient-to-b from-amber-500 to-orange-500 rounded mr-3"></span>
                        策略对比雷达
                    </h2>
                    <div class="glass-card p-6">
                        <canvas id="radar-chart" height="300"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <!-- Top 10 表现最佳 -->
        <section class="mb-12">
            <h2 class="text-2xl font-bold mb-6 flex items-center">
                <span class="w-2 h-8 bg-gradient-to-b from-rose-500 to-pink-500 rounded mr-3"></span>
                Top 10 表现最佳组合
            </h2>
            <div class="glass-card p-6 overflow-hidden">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="top10-grid"></div>
            </div>
        </section>

        <!-- 页脚 -->
        <footer class="text-gray-500 text-sm text-center py-8 border-t border-gray-800">
            <p>数据来源：沪深300成分股历史日线数据 | 生成时间：<span id="generated-time"></span></p>
            <p class="mt-2">系统版本：v2.0.0 | OpenClaw量化交易平台</p>
        </footer>
    </div>

    <!-- 数据加载脚本 -->
    <script>
        // 全局数据存储
        let allData = [];
        let strategySummary = [];
        let filteredData = [];
        
        // 策略颜色
        const strategyColors = {
            'MACrossStrategy': '#3b82f6',
            'MACDCrossStrategy': '#10b981',
            'RSIStrategy': '#f59e0b',
            'BollingerStrategy': '#ef4444',
            'TAConfluenceStrategy': '#8b5cf6'
        };
        
        const strategyNames = {
            'MACrossStrategy': 'MA均线',
            'MACDCrossStrategy': 'MACD',
            'RSIStrategy': 'RSI',
            'BollingerStrategy': '布林带',
            'TAConfluenceStrategy': '多因子共振'
        };

        // 加载数据
        async function loadData() {
            try {
                console.log('📥 开始加载数据...');
                const start = performance.now();
                
                const [dataRes, summaryRes] = await Promise.all([
                    fetch('../results/hs300_full/partial_results.csv'),
                    fetch('../results/hs300_full/strategy_summary.csv')
                ]);
                
                if (!dataRes.ok || !summaryRes.ok) {
                    throw new Error(`HTTP error: ${dataRes.status} ${summaryRes.status}`);
                }
                
                const dataText = await dataRes.text();
                const summaryText = await summaryRes.text();
                
                console.log('📊 数据大小:', {
                    partial: dataText.length, 
                    summary: summaryText.length
                });
                
                allData = csvToArray(dataText);
                strategySummary = csvToArray(summaryText);
                
                console.log('⏱️ 解析耗时:', performance.now() - start, 'ms');
                console.log('📈 数据量:', { allData: allData.length, summary: strategySummary.length });
                
                // 更新显示
                updateKPIs();
                renderStrategyTable();
                renderDetailedTable();
                renderCharts();
                renderTop10();
                
                // 更新时间
                const now = new Date();
                document.getElementById('update-time').textContent = now.toLocaleString('zh-CN');
                document.getElementById('generated-time').textContent = now.toLocaleString('zh-CN');
                
                console.log('✅ 数据加载完成');
                
            } catch (error) {
                console.error('数据加载失败:', error);
                showError(`无法加载数据: ${error.message}`);
            }
        }

        // CSV转数组（优化版）
        function csvToArray(text) {
            // 移除BOM
            if (text.charCodeAt(0) === 0xFEFF) {
                text = text.slice(1);
            }
            
            // 快速分割行（假设CSV是简单格式，无复杂引号）
            const lines = text.trim().split('\n');
            if (lines.length < 2) return [];
            
            const headers = lines[0].split(',').map(h => h.trim());
            const result = [];
            
            // 批量处理，避免单条解析过慢
            for (let i = 1; i < lines.length; i++) {
                const line = lines[i];
                if (!line.trim()) continue;
                
                // 简单分割（数据中没有逗号在引号内的情况）
                const values = line.split(',');
                if (values.length < headers.length) continue;
                
                const obj = {};
                let hasInvalid = false;
                
                for (let j = 0; j < headers.length; j++) {
                    let val = (values[j] || '').trim();
                    
                    // 快速数字判断
                    if (val && val !== '-' && !isNaN(val) && val !== '') {
                        const num = parseFloat(val);
                        if (!isNaN(num)) {
                            val = num;
                        }
                    }
                    
                    obj[headers[j]] = val;
                    
                    // 检查必要字段
                    if (j === 0 && !obj[headers[j]]) {
                        hasInvalid = true;
                        break;
                    }
                }
                
                if (!hasInvalid) {
                    result.push(obj);
                }
            }
            
            console.log(`✅ 解析完成: ${result.length} 条记录`);
            return result;
        }

        // 更新KPI卡片
        function updateKPIs() {
            const totalBacktests = allData.length;
            const uniqueStocks = new Set(allData.map(d => d.symbol)).size;
            
            // 找出最佳策略（平均测试收益最高）
            const best = strategySummary[0];
            
            document.getElementById('total-backtests').textContent = totalBacktests.toLocaleString();
            document.getElementById('stock-count').textContent = uniqueStocks;
            document.getElementById('best-strategy').textContent = strategyNames[best.strategy] || best.strategy;
            document.getElementById('best-return').textContent = `${parseFloat(best.avg_return).toFixed(2)}%`;
        }

        // 渲染策略汇总表
        function renderStrategyTable() {
            const tbody = document.getElementById('strategy-table-body');
            tbody.innerHTML = strategySummary.map(row => `
                <tr class="border-b border-gray-800 hover:bg-white/5 transition-colors">
                    <td class="font-medium" style="color: ${strategyColors[row.strategy]}">
                        ${strategyNames[row.strategy] || row.strategy}
                    </td>
                    <td class="text-right font-bold ${row.avg_return >= 0 ? 'text-green-400' : 'text-red-400'}">
                        ${parseFloat(row.avg_return).toFixed(2)}%
                    </td>
                    <td class="text-right text-gray-400">${parseFloat(row.std_return).toFixed(2)}%</td>
                    <td class="text-right ${Math.abs(parseFloat(row.avg_maxdd)) < 5 ? 'text-yellow-400' : 'text-red-400'}">
                        ${parseFloat(row.avg_maxdd).toFixed(2)}%
                    </td>
                    <td class="text-right ${row.avg_sharpe >= 0 ? 'text-green-400' : 'text-red-400'}">
                        ${parseFloat(row.avg_sharpe).toFixed(2)}
                    </td>
                    <td class="text-right text-gray-400">${parseFloat(row.avg_winrate).toFixed(1)}%</td>
                    <td class="text-right text-gray-500">${row.stock_count}</td>
                </tr>
            `).join('');
        }

        // 渲染详细表格
        function renderDetailedTable() {
            const filter = document.getElementById('filter-strategy').value;
            const sortBy = document.getElementById('sort-by').value;
            
            filteredData = allData.filter(row => 
                filter === 'all' || row.strategy === filter
            );
            
            filteredData.sort((a, b) => b[sortBy] - a[sortBy]);
            
            const tbody = document.getElementById('detailed-table-body');
            tbody.innerHTML = filteredData.slice(0, 100).map(row => {
                const ret = parseFloat(row.test_return_pct) || 0;
                const colorClass = ret >= 0 ? 'text-green-400' : 'text-red-400';
                const strategyClass = `strategy-${row.strategy.toLowerCase().replace('crossstrategy', '').replace('strategy', '')}`;
                
                return `
                    <tr class="border-b border-gray-800 hover:bg-white/5 transition-colors">
                        <td class="font-medium text-gray-300">${row.symbol}</td>
                        <td class="text-sm" style="color: ${strategyColors[row.strategy]}">
                            ${strategyNames[row.strategy] || row.strategy}
                        </td>
                        <td class="text-right font-bold ${colorClass}">
                            ${ret.toFixed(2)}%
                        </td>
                        <td class="text-right text-gray-400">${parseFloat(row.test_sharpe || 0).toFixed(2)}</td>
                        <td class="text-right text-red-400">${parseFloat(row.test_maxdd_pct || 0).toFixed(2)}%</td>
                        <td class="text-right text-gray-400">${parseFloat(row.win_rate_pct || 0).toFixed(1)}%</td>
                        <td class="text-right text-gray-500">${row.test_trades || 0}</td>
                    </tr>
                `;
            }).join('');
            
            // 更新计数
            const info = document.createElement('div');
            info.className = 'text-gray-500 text-sm mb-4';
            info.innerHTML = `显示 <span class="text-white font-medium">${filteredData.length}</span> 条记录 (共 <span class="text-white font-medium">${allData.length}</span> 条)`;
            const container = document.querySelector('.data-table').parentElement;
            const existingInfo = container.querySelector('.text-gray-500.text-sm.mb-4');
            if (existingInfo) existingInfo.remove();
            container.insertBefore(info, container.firstChild);
        }

        // 渲染图表
        let charts = {};
        
        function renderCharts() {
            // 收益分布直方图
            const returns = allData.map(d => parseFloat(d.test_return_pct) || 0).filter(r => !isNaN(r));
            const ctx1 = document.getElementById('return-distribution-chart').getContext('2d');
            
            if (charts.distribution) charts.distribution.destroy();
            
            charts.distribution = new Chart(ctx1, {
                type: 'bar',
                data: {
                    labels: ['<-10%', '-10%~-5%', '-5%~0%', '0%~5%', '5%~10%', '10%~15%', '>15%'],
                    datasets: [{
                        label: '策略数量',
                        data: [
                            returns.filter(r => r < -10).length,
                            returns.filter(r => r >= -10 && r < -5).length,
                            returns.filter(r => r >= -5 && r < 0).length,
                            returns.filter(r => r >= 0 && r < 5).length,
                            returns.filter(r => r >= 5 && r < 10).length,
                            returns.filter(r => r >= 10 && r < 15).length,
                            returns.filter(r => r >= 15).length
                        ],
                        backgroundColor: 'rgba(139, 92, 246, 0.6)',
                        borderColor: 'rgba(139, 92, 246, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        title: { display: true, text: '测试收益分布', color: '#a5b4fc' }
                    },
                    scales: {
                        y: { 
                            ticks: { color: '#9ca3af' },
                            grid: { color: 'rgba(255,255,255,0.1)' }
                        },
                        x: {
                            ticks: { color: '#9ca3af' },
                            grid: { display: false }
                        }
                    }
                }
            });

            // 策略雷达图（5个指标）
            const ctx2 = document.getElementById('radar-chart').getContext('2d');
            
            if (charts.radar) charts.radar.destroy();
            
            // 归一化数据到0-1范围用于雷达图
            const maxReturn = Math.max(...strategySummary.map(s => Math.abs(s.avg_return)));
            const maxDD = Math.max(...strategySummary.map(s => Math.abs(s.avg_maxdd)));
            const maxSharpe = Math.max(...strategySummary.map(s => Math.abs(s.avg_sharpe) || 0.1));
            
            charts.radar = new Chart(ctx2, {
                type: 'radar',
                data: {
                    labels: ['平均收益', '稳定性(1/σ)', '风险控制', '综合评分', '样本覆盖'],
                    datasets: strategySummary.map((s, i) => ({
                        label: strategyNames[s.strategy],
                        data: [
                            (s.avg_return / maxReturn + 1) / 2, // 收益归一化
                            1 - Math.min(s.avg_sharpe / maxSharpe, 1), // 夏普(反转)
                            1 - Math.min(Math.abs(s.avg_maxdd) / maxDD, 1), // 回撤(反转)
                            (s.avg_return / 10 + s.avg_sharpe / 2 + (1 - Math.abs(s.avg_maxdd)/10)) / 3, // 综合分
                            Math.min(s.stock_count / 10, 1)
                        ],
                        backgroundColor: `${strategyColors[s.strategy]}33`,
                        borderColor: strategyColors[s.strategy],
                        borderWidth: 2,
                        pointBackgroundColor: strategyColors[s.strategy]
                    }))
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'bottom',
                            labels: { color: '#a5b4fc', boxWidth: 12, font: { size: 10 } }
                        }
                    },
                    scales: {
                        r: {
                            beginAtZero: true,
                            max: 1,
                            ticks: { display: false },
                            grid: { color: 'rgba(255,255,255,0.1)' },
                            pointLabels: { color: '#9ca3af', font: { size: 11 } }
                        }
                    }
                }
            });
        }

        // 渲染Top 10
        function renderTop10() {
            const top10 = [...allData]
                .sort((a, b) => b.test_return_pct - a.test_return_pct)
                .slice(0, 10);
            
            const grid = document.getElementById('top10-grid');
            grid.innerHTML = top10.map((row, idx) => `
                <div class="glass-card p-4 hover:bg-white/10 transition-all duration-300 cursor-pointer transform hover:scale-[1.02]">
                    <div class="flex items-start justify-between mb-2">
                        <span class="text-gray-400 text-sm">#${idx + 1}</span>
                        <span class="px-2 py-1 text-xs rounded-full" style="background: ${strategyColors[row.strategy]}33; color: ${strategyColors[row.strategy]}; border: 1px solid ${strategyColors[row.strategy]}">
                            ${strategyNames[row.strategy]}
                        </span>
                    </div>
                    <div class="text-xl font-bold text-gray-100 mb-1">${row.symbol}</div>
                    <div class="text-3xl font-bold ${row.test_return_pct >= 0 ? 'text-green-400' : 'text-red-400'}">
                        ${parseFloat(row.test_return_pct).toFixed(2)}%
                    </div>
                    <div class="mt-3 text-xs text-gray-500 space-y-1">
                        <div class="flex justify-between">
                            <span>夏普:</span>
                            <span class="${row.test_sharpe >= 0 ? 'text-green-400' : 'text-red-400'}">${parseFloat(row.test_sharpe || 0).toFixed(2)}</span>
                        </div>
                        <div class="flex justify-between">
                            <span>回撤:</span>
                            <span class="text-red-400">${parseFloat(row.test_maxdd_pct).toFixed(2)}%</span>
                        </div>
                        <div class="flex justify-between">
                            <span>交易:</span>
                            <span>${row.test_trades || 0}次</span>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // 排序
        function sortData(field) {
            sortField = field;
            renderDetailedTable();
        }

        // 过滤和刷新
        document.getElementById('filter-strategy').addEventListener('change', renderDetailedTable);
        document.getElementById('sort-by').addEventListener('change', renderDetailedTable);
        document.getElementById('refresh-btn').addEventListener('click', () => {
            window.location.reload();
        });

        // 错误提示
        function showError(msg) {
            document.body.innerHTML = `
                <div class="flex items-center justify-center min-h-screen bg-gray-900">
                    <div class="glass-card p-8 max-w-md text-center">
                        <div class="text-red-400 text-4xl mb-4">⚠️</div>
                        <h2 class="text-xl font-bold mb-2">数据加载失败</h2>
                        <p class="text-gray-400">${msg}</p>
                        <button onclick="location.reload()" class="mt-4 bg-indigo-600 px-4 py-2 rounded-lg hover:bg-indigo-700 transition-colors">
                            重试
                        </button>
                    </div>
                </div>
            `;
        }

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            loadData();
        });
    </script>
</body>
</html>
