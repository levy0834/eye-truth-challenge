# 忽略Python缓存
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境
venv/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo

# 数据文件（大文件，不提交）
data/raw/*.csv
data/raw/*/*.csv
data/processed/*
data/cache/*
!data/raw/.gitkeep

# 结果文件（动态生成）
results/*
!results/.gitkeep

# 环境变量
.env
*.env

# 日志
*.log

# 操作系统
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# 打包
dist/
build/
*.egg-info
